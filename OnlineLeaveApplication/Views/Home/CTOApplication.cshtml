
@{
    ViewBag.Title = "CTOApplication";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h5>Compensatory Time-Off Balances</h5>
<div class="row">
    <div class="col-md-3 col-sm-6 col-12">
        <div class="info-box">
            <span class="info-box-icon bg-info"><i class="far fa-clock"></i></span>

            <div class="info-box-content">
                <span class="info-box-text">CTO</span>
                <span class="info-box-number">@ViewBag.CTO</span>
            </div>
            <!-- /.info-box-content -->
        </div>
        <!-- /.info-box -->
    </div>
    <!-- /.col --> 
</div>
<hr />

