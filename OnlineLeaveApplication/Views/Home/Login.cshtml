
@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <title>DILG Regional Order Management System | Login</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">

    <link rel="stylesheet" href="~/plugins/fontawesome-free/css/all.min.css">
    <link rel="stylesheet" href="~/dist/css/adminlte.min.css">

    <style>
        :root {
            --page-bg: #f3f4f6;
            --panel-bg: #ffffff;
            --text-main: #23272f;
            --text-muted: #6b7280;
            --border: #d8dde4;
            --field-bg: #fbfbfc;
            --button-bg: #2f343b;
            --button-bg-hover: #1f2329;
            --error-bg: #f8eeee;
            --error-border: #e7caca;
            --error-text: #8a3434;
        }

        * {
            box-sizing: border-box;
        }

        body.login-page {
            min-height: 100vh;
            margin: 0;
            padding: 32px 16px;
            display: flex;
            align-items: center;
            justify-content: center;
            background: var(--page-bg);
            color: var(--text-main);
            font-family: Arial, Helvetica, sans-serif;
        }

        .login-shell {
            width: 100%;
            max-width: 420px;
        }

        .login-panel {
            width: 100%;
            padding: 38px;
            border: 1px solid var(--border);
            border-radius: 8px;
            background: var(--panel-bg);
            box-shadow: 0 18px 45px rgba(31, 35, 41, 0.08);
        }

        .login-logo {
            display: block;
            width: 128px;
            height: 128px;
            margin: 0 auto 20px;
            object-fit: contain;
        }

        .system-name {
            margin: 0 0 10px;
            color: var(--text-main);
            font-size: 1.65rem;
            font-weight: 700;
            line-height: 1.2;
        }

        .login-copy {
            margin: 0 0 30px;
            color: var(--text-muted);
            font-size: 0.98rem;
            line-height: 1.5;
        }

        .form-group {
            margin-bottom: 18px;
        }

        .form-label {
            display: block;
            margin-bottom: 8px;
            color: var(--text-main);
            font-size: 0.88rem;
            font-weight: 700;
        }

        .input-wrap {
            position: relative;
        }

        .input-wrap .form-control {
            width: 100%;
            height: 48px;
            max-width: none;
            padding: 12px 44px 12px 14px;
            border: 1px solid var(--border);
            border-radius: 6px;
            background: var(--field-bg);
            color: var(--text-main);
            font-size: 0.98rem;
            transition: border-color 160ms ease, box-shadow 160ms ease, background-color 160ms ease;
        }

        .input-wrap .form-control:focus {
            border-color: #8d949e;
            background: #ffffff;
            box-shadow: 0 0 0 3px rgba(47, 52, 59, 0.1);
        }

        .input-icon {
            position: absolute;
            top: 50%;
            right: 15px;
            transform: translateY(-50%);
            color: #9aa1aa;
            pointer-events: none;
        }

        .login-message {
            min-height: 22px;
            margin: 4px 0 18px;
            color: var(--error-text);
            font-size: 0.92rem;
            line-height: 1.45;
        }

        .login-message:not(:empty) {
            padding: 10px 12px;
            border: 1px solid var(--error-border);
            border-radius: 6px;
            background: var(--error-bg);
        }

        .login-button {
            width: 100%;
            min-height: 48px;
            border: 0;
            border-radius: 6px;
            background: var(--button-bg);
            color: #ffffff;
            font-size: 0.98rem;
            font-weight: 700;
            transition: background-color 160ms ease, transform 160ms ease;
        }

        .login-button:hover,
        .login-button:focus {
            background: var(--button-bg-hover);
            color: #ffffff;
        }

        .login-button:active {
            transform: translateY(1px);
        }

        @@media (max-width: 480px) {
            body.login-page {
                padding: 20px 14px;
            }

            .login-panel {
                padding: 28px 22px;
            }

            .login-logo {
                width: 104px;
                height: 104px;
                margin-bottom: 18px;
            }

            .system-name {
                font-size: 1.38rem;
            }
        }
    </style>
</head>
<body class="hold-transition login-page">
    <main class="login-shell" aria-labelledby="login-title">
        <section class="login-panel">
            <img src="~/dist/img/DILG LOGO.png" class="login-logo" alt="DILG Logo">
            <h1 class="system-name" id="login-title">DILG Regional Order Management System</h1>
            <p class="login-copy">Sign in with your account credentials.</p>

            <form action="/Home/Login" method="post">
                <div class="form-group">
                    <label class="form-label" for="Username">Username</label>
                    <div class="input-wrap">
                        <input type="text" class="form-control" id="Username" placeholder="Enter username" name="Username" autocomplete="username">
                        <span class="input-icon fas fa-user" aria-hidden="true"></span>
                    </div>
                </div>

                <div class="form-group">
                    <label class="form-label" for="Password">Password</label>
                    <div class="input-wrap">
                        <input type="password" class="form-control" id="Password" placeholder="Enter password" name="Password" autocomplete="current-password">
                        <span class="input-icon fas fa-lock" aria-hidden="true"></span>
                    </div>
                </div>

                <div class="login-message" role="alert">@ViewBag.Message</div>

                <button type="submit" class="login-button">Sign In</button>
            </form>
        </section>
    </main>

    <script src="~/plugins/jquery/jquery.min.js"></script>
    <script src="~/plugins/bootstrap/js/bootstrap.bundle.min.js"></script>
    <script src="~/dist/js/adminlte.min.js"></script>
</body>
</html>
