@{
    ViewBag.Title = "Regional Order Calendar";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="ro-page-header">
    <div>
        <h1 class="ro-page-title">Regional Order Calendar</h1>
        <p class="ro-page-subtitle">Review activity dates, scheduled orders, and participant assignments.</p>
    </div>
    <div class="ro-page-actions">
        <a class="btn ro-btn btn-outline-secondary" href="@Url.Action("RegionalOrders", "Home")">
            <i class="fas fa-list"></i> My Orders
        </a>
        @{ if (Session["Status"] != null && Convert.ToInt32(Session["Status"]) != 0)
            {
                <a class="btn ro-btn ro-btn-primary" href="@Url.Action("ManageRegionalOrder", "Home")">
                    <i class="fas fa-plus"></i> New Regional Order
                </a>
            }
        }
    </div>
</div>

<div class="row ro-calendar-grid">
    <div class="col-lg-9">
        <section class="ro-card">
            <div class="ro-card-header">
                <div>
                    <h2 class="ro-card-title">Regional Order Schedule</h2>
                    <p class="ro-card-subtitle">Calendar events are grouped by activity date ranges.</p>
                </div>
            </div>
            <div class="ro-card-body ro-card-body-flush">
                <div id="regional-order-calendar"></div>
            </div>
        </section>
    </div>
    <div class="col-lg-3">
        <section class="ro-card">
            <div class="ro-card-header">
                <div>
                    <h2 class="ro-card-title"><i class="fas fa-calendar-plus text-primary"></i> Upcoming</h2>
                    <p class="ro-card-subtitle">Future regional order activities.</p>
                </div>
            </div>
            <div class="ro-card-body ro-card-body-flush">
                <div class="list-group list-group-flush ro-status-list" id="upcoming-regional-orders"></div>
            </div>
        </section>
        <section class="ro-card">
            <div class="ro-card-header">
                <div>
                    <h2 class="ro-card-title"><i class="fas fa-calendar-day text-warning"></i> Today</h2>
                    <p class="ro-card-subtitle">Regional orders active today.</p>
                </div>
            </div>
            <div class="ro-card-body ro-card-body-flush">
                <div class="list-group list-group-flush ro-status-list is-today" id="today-regional-orders"></div>
            </div>
        </section>
        <section class="ro-card">
            <div class="ro-card-header">
                <div>
                    <h2 class="ro-card-title"><i class="fas fa-history text-success"></i> Past</h2>
                    <p class="ro-card-subtitle">Completed or elapsed activity dates.</p>
                </div>
            </div>
            <div class="ro-card-body ro-card-body-flush">
                <div class="list-group list-group-flush ro-status-list is-past" id="past-regional-orders"></div>
            </div>
        </section>
    </div>
</div>

<div class="modal fade" id="modal_regional_order_details" data-backdrop="static" data-keyboard="false">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h4 class="modal-title">Regional Order Details</h4>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <dl class="row mb-0">
                    <dt class="col-sm-3">Regional Order No.</dt>
                    <dd class="col-sm-9" id="ro-detail-number"></dd>

                    <dt class="col-sm-3">Title</dt>
                    <dd class="col-sm-9" id="ro-detail-title"></dd>

                    <dt class="col-sm-3">Date Issued</dt>
                    <dd class="col-sm-9" id="ro-detail-date-issued"></dd>

                    <dt class="col-sm-3">Venue</dt>
                    <dd class="col-sm-9" id="ro-detail-venue"></dd>

                    <dt class="col-sm-3">Activity Dates</dt>
                    <dd class="col-sm-9">
                        <ul class="mb-0 pl-3" id="ro-detail-activity-dates"></ul>
                    </dd>

                    <dt class="col-sm-3">Participants</dt>
                    <dd class="col-sm-9">
                        <ul class="mb-0 pl-3" id="ro-detail-participants"></ul>
                    </dd>

                    <dt class="col-sm-3">Remarks</dt>
                    <dd class="col-sm-9" id="ro-detail-remarks"></dd>

                    <dt class="col-sm-3">Attached PDF</dt>
                    <dd class="col-sm-9">
                        <a id="ro-detail-pdf" href="#" target="_blank" title="Open attached PDF">
                            <i class="fas fa-file-pdf fa-lg text-danger"></i>
                        </a>
                    </dd>
                </dl>
            </div>
            <div class="modal-footer justify-content-between">
                <button type="button" class="btn btn-default" data-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

<script>
    $(function () {
        var calendarEl = document.getElementById('regional-order-calendar');
        var calendarEvents = [];

        function setText(selector, value, emptyText) {
            $(selector).text(value || emptyText || '');
        }

        function setList(selector, values, emptyText) {
            var list = $(selector);
            list.empty();

            if (!values || values.length === 0) {
                list.append($('<li />').text(emptyText || 'None'));
                return;
            }

            values.forEach(function (value) {
                list.append($('<li />').text(value));
            });
        }

        function showRegionalOrderDetails(details) {
            setText('#ro-detail-number', details.regionalOrderNumber, 'N/A');
            setText('#ro-detail-title', details.title, 'N/A');
            setText('#ro-detail-date-issued', details.regionalOrderDate, 'N/A');
            setText('#ro-detail-venue', details.venue, 'N/A');
            setText('#ro-detail-remarks', details.remarks, 'N/A');
            setList('#ro-detail-activity-dates', details.activityDates, 'No activity dates');
            setList('#ro-detail-participants', details.participants, 'No participants');
            $('#ro-detail-pdf').attr('href', details.pdfUrl || '#');
            $('#modal_regional_order_details').modal('show');
        }

        function getEventDetails(eventItem) {
            return eventItem.extendedProps || eventItem;
        }

        function renderRegionalOrderList(selector, events, emptyText) {
            var container = $(selector);
            container.empty();

            if (!events.length) {
                container.append(
                    $('<div />')
                        .addClass('list-group-item text-muted')
                        .text(emptyText)
                );
                return;
            }

            events.forEach(function (eventItem) {
                var details = getEventDetails(eventItem);
                var item = $('<button />')
                    .attr('type', 'button')
                    .addClass('list-group-item list-group-item-action')
                    .on('click', function () {
                        showRegionalOrderDetails(details);
                    });

                item.append($('<div />')
                    .addClass('font-weight-bold')
                    .text(details.regionalOrderNumber || 'Regional Order'));
                item.append($('<div />')
                    .addClass('small')
                    .text(details.title || 'No title'));
                item.append($('<div />')
                    .addClass('small text-muted')
                    .text(details.rangeLabel || 'No activity date'));

                container.append(item);
            });
        }

        function renderStatusCards(events) {
            renderRegionalOrderList(
                '#upcoming-regional-orders',
                events.filter(function (eventItem) {
                    return getEventDetails(eventItem).statusCategory === 'upcoming';
                }),
                'No upcoming regional orders'
            );
            renderRegionalOrderList(
                '#today-regional-orders',
                events.filter(function (eventItem) {
                    return getEventDetails(eventItem).statusCategory === 'today';
                }),
                'No regional orders today'
            );
            renderRegionalOrderList(
                '#past-regional-orders',
                events.filter(function (eventItem) {
                    return getEventDetails(eventItem).statusCategory === 'past';
                }),
                'No past regional orders'
            );
        }

        var calendar = new FullCalendar.Calendar(calendarEl, {
            plugins: ['bootstrap', 'dayGrid', 'timeGrid'],
            themeSystem: 'bootstrap',
            header: {
                left: 'prev,next today',
                center: 'title',
                right: 'dayGridMonth,timeGridWeek,timeGridDay'
            },
            defaultView: 'dayGridMonth',
            eventLimit: true,
            events: function (fetchInfo, successCallback, failureCallback) {
                $.ajax({
                    url: '/RegionalOrder/GetMyRegionalOrderCalendarEvents',
                    type: 'GET',
                    dataType: 'json',
                    success: function (events) {
                        calendarEvents = events || [];
                        renderStatusCards(calendarEvents);
                        successCallback(calendarEvents);
                    },
                    error: function () {
                        renderStatusCards([]);
                        failureCallback();
                    }
                });
            },
            eventClick: function (info) {
                info.jsEvent.preventDefault();
                var details = info.event.extendedProps;
                showRegionalOrderDetails(details.extendedProps || details);
            }
        });

        renderStatusCards(calendarEvents);
        calendar.render();
    });
</script>
